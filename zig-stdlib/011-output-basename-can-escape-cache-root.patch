+fn validateOutputBasename(basename: []const u8) void {
+    if (basename.len == 0) @panic("basename must not be empty");
+    if (Dir.path.isAbsolute(basename)) @panic("basename must not be absolute");
+
+    var it = Dir.path.componentIterator(basename);
+    while (it.next()) |component| {
+        if (mem.eql(u8, component.name, "..")) {
+            @panic("basename must not contain '..' path components");
+        }
+    }
+}
