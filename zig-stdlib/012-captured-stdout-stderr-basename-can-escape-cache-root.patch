+fn dupeCapturedBasename(run: *Run, basename: []const u8) []const u8 {
+    if (basename.len == 0) @panic("basename must not be empty");
+    if (!mem.eql(u8, Dir.path.basename(basename), basename) or
+        mem.eql(u8, basename, ".") or
+        mem.eql(u8, basename, ".."))
+    {
+        @panic("basename must be a single path component");
+    }
+    return run.step.owner.dupe(basename);
+}
