+fn validateSymlinkTarget(file_name: []const u8, link_name: []const u8) error{Invalid}!void {
+    if (link_name.len > 0 and link_name[0] == '/') return error.Invalid;
+
+    var depth: usize = 0;
+    var file_it = std.mem.tokenizeScalar(u8, file_name, '/');
+    while (file_it.next()) |_| depth += 1;
+    depth -|= 1;
+
+    var link_it = std.mem.tokenizeScalar(u8, link_name, '/');
+    while (link_it.next()) |component| {
+        if (std.mem.eql(u8, component, ".")) continue;
+        if (std.mem.eql(u8, component, "..")) {
+            if (depth == 0) return error.Invalid;
+            depth -= 1;
+            continue;
+        }
+        depth += 1;
+    }
+}
