+fn assertValidSubPath(sub_path: []const u8) void {
+    var component_iterator: std.fs.path.NativeComponentIterator = .init(sub_path);
+    if (component_iterator.root() != null) {
+        std.debug.panic("sub_path is expected to be relative to the WriteFile root, but was this absolute path: '{s}'", .{sub_path});
+    }
+
+    var depth: usize = 0;
+    while (component_iterator.next()) |component| {
+        if (std.mem.eql(u8, component.name, ".") or component.name.len == 0) continue;
+        if (std.mem.eql(u8, component.name, "..")) {
+            if (depth == 0) {
+                std.debug.panic("sub_path escapes the WriteFile root: '{s}'", .{sub_path});
+            }
+            depth -= 1;
+            continue;
+        }
+        depth += 1;
+    }
+}
